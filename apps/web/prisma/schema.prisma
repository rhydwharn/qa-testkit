// QA Test Management Tool — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenants ─────────────────────────────────────────────────────────────────

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

enum LogoDisplay {
  LOGO_ONLY
  NAME_ONLY
  LOGO_AND_NAME
}

model Tenant {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  logoStorageKey String?
  logoUrl        String?
  logoDisplay    LogoDisplay @default(NAME_ONLY)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  members  TenantMember[]
  projects Project[]
  apiKeys  ApiKey[]
  invites  TenantInvite[]

  @@index([slug])
}

model TenantMember {
  id       String     @id @default(cuid())
  tenantId String
  userId   String
  role     TenantRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model TenantInvite {
  id        String     @id @default(cuid())
  tenantId  String
  email     String
  role      TenantRole @default(MEMBER)
  token     String     @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed; null when using OAuth
  role          UserRole  @default(TESTER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  tenantMembers      TenantMember[]
  projectMembers     ProjectMember[]
  testCaseExecutions TestCaseExecution[]
  createdCycles      TestCycle[]         @relation("CycleCreator")
  apiKeys            ApiKey[]
  comments           Comment[]
  createdFilters     SavedFilter[]       @relation("FilterCreator")
  attachments        Attachment[]
}

enum UserRole {
  ADMIN
  LEAD
  TESTER
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  prefix      String    // first 8 chars shown in UI
  userId      String
  tenantId    String?
  projectId   String?
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([keyHash])
  @@index([tenantId])
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id              String   @id @default(cuid())
  key             String   // e.g. "SHOP" — unique per tenant via @@unique([tenantId, key])
  name            String
  description     String?
  tenantId        String
  jiraProjectKey  String?
  jiraBaseUrl     String?  // e.g. "https://myorg.atlassian.net"
  jiraApiToken    String?  // encrypted at app level
  jiraUserEmail   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members        ProjectMember[]
  folders        Folder[]
  testCases      TestCase[]
  testCycles     TestCycle[]
  testPlans      TestPlan[]
  environments   Environment[]
  builds         Build[]
  labels         Label[]
  components     Component[]
  statuses       Status[]
  priorities     Priority[]
  customFields   CustomField[]
  apiKeys        ApiKey[]
  automationRuns AutomationRun[]
  savedFilters   SavedFilter[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(TESTER)
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

enum ProjectRole {
  OWNER
  LEAD
  TESTER
  VIEWER
}

// ─── Folders ─────────────────────────────────────────────────────────────────

model Folder {
  id        String     @id @default(cuid())
  name      String
  type      FolderType
  parentId  String?
  projectId String
  createdAt DateTime   @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent     Folder?    @relation("FolderTree", fields: [parentId], references: [id])
  children   Folder[]   @relation("FolderTree")
  testCases  TestCase[]
  testCycles TestCycle[]
  testPlans  TestPlan[]

  @@index([projectId, type])
}

enum FolderType {
  CASE
  CYCLE
  PLAN
}

// ─── Project Settings ─────────────────────────────────────────────────────────

model Environment {
  id        String   @id @default(cuid())
  name      String
  projectId String
  createdAt DateTime @default(now())

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCycles TestCycle[]

  @@unique([projectId, name])
}

model Build {
  id        String   @id @default(cuid())
  name      String
  projectId String
  createdAt DateTime @default(now())

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCycles TestCycle[]

  @@unique([projectId, name])
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  projectId String
  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCaseLabel[]

  @@unique([projectId, name])
}

model Component {
  id        String   @id @default(cuid())
  name      String
  projectId String
  createdAt DateTime @default(now())

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCaseComponent[]

  @@unique([projectId, name])
}

model Status {
  id        String     @id @default(cuid())
  name      String
  color     String     @default("#6366f1")
  type      StatusType
  isDefault Boolean    @default(false)
  projectId String
  createdAt DateTime   @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name, type])
}

enum StatusType {
  CASE
  CYCLE
  PLAN
  EXECUTION
}

model Priority {
  id        String   @id @default(cuid())
  name      String
  level     Int      // 1=Critical, 2=High, 3=Medium, 4=Low
  color     String   @default("#6366f1")
  isDefault Boolean  @default(false)
  projectId String
  createdAt DateTime @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases  TestCase[]
  testCycles TestCycle[]
  testPlans  TestPlan[]

  @@unique([projectId, name])
}

model CustomField {
  id        String          @id @default(cuid())
  name      String
  fieldType CustomFieldType
  options   String[]        // for SELECT/MULTI_SELECT types
  required  Boolean         @default(false)
  entityType EntityType
  projectId String
  createdAt DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name, entityType])
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  CHECKBOX
  USER
}

enum EntityType {
  TEST_CASE
  TEST_CYCLE
  TEST_PLAN
  EXECUTION
}

// ─── Test Cases ───────────────────────────────────────────────────────────────

model TestCase {
  id          String       @id @default(cuid())
  key         String       // e.g. "TC-1"
  summary     String
  description String?      @db.Text
  status      CaseStatus   @default(DRAFT)
  isArchived  Boolean      @default(false)
  priorityId  String?
  folderId    String?
  projectId   String
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // JIRA requirement linking (lightweight)
  jiraRequirementKeys String[] // e.g. ["SHOP-123", "SHOP-456"]

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder     Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  priority   Priority?    @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  versions   TestCaseVersion[]
  labels     TestCaseLabel[]
  components TestCaseComponent[]
  cycleLinks TestCycleCase[]

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([projectId, isArchived])
}

enum CaseStatus {
  DRAFT
  READY
  DEPRECATED
}

model TestCaseLabel {
  testCaseId String
  labelId    String

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  label    Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([testCaseId, labelId])
}

model TestCaseComponent {
  testCaseId  String
  componentId String

  testCase  TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@id([testCaseId, componentId])
}

model TestCaseVersion {
  id           String   @id @default(cuid())
  testCaseId   String
  versionNo    Int
  isLatest     Boolean  @default(true)
  customFields Json     @default("{}")
  createdAt    DateTime @default(now())

  testCase TestCase    @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  steps    TestStep[]
  executions TestCaseExecution[]

  @@unique([testCaseId, versionNo])
  @@index([testCaseId, isLatest])
}

model TestStep {
  id             String  @id @default(cuid())
  versionId      String
  order          Int
  stepDetails    String  @db.Text
  expectedResult String? @db.Text
  testData       String? @db.Text

  version         TestCaseVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  stepExecutions  TestStepExecution[]

  @@index([versionId, order])
}

// ─── Test Cycles ──────────────────────────────────────────────────────────────

model TestCycle {
  id            String      @id @default(cuid())
  key           String      // e.g. "CYC-1"
  summary       String
  description   String?     @db.Text
  status        CycleStatus @default(DRAFT)
  isArchived    Boolean     @default(false)
  priorityId    String?
  environmentId String?
  buildId       String?
  startDate     DateTime?
  endDate       DateTime?
  folderId      String?
  projectId     String
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy         User?        @relation("CycleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  folder            Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  priority          Priority?    @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  environment       Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  build             Build?       @relation(fields: [buildId], references: [id], onDelete: SetNull)
  cases             TestCycleCase[]
  executions        TestCaseExecution[]
  planLinks         TestPlanCycle[]
  automationRuns    AutomationRun[]

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([projectId, isArchived])
}

enum CycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model TestCycleCase {
  id          String @id @default(cuid())
  testCycleId String
  testCaseId  String
  order       Int    @default(0)

  testCycle TestCycle @relation(fields: [testCycleId], references: [id], onDelete: Cascade)
  testCase  TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testCycleId, testCaseId])
}

// ─── Test Executions ──────────────────────────────────────────────────────────

model TestCaseExecution {
  id                String          @id @default(cuid())
  testCycleId       String
  testCaseId        String
  testCaseVersionId String
  status            ExecutionStatus @default(NOT_RUN)
  assigneeId        String?
  executionMethod   String?         @default("MANUAL")  // MANUAL, CYPRESS, PLAYWRIGHT, JEST, SELENIUM, TESTNG
  duration          Int?            // milliseconds
  actualResult      String?         @db.Text
  comment           String?         @db.Text
  customFields      Json            @default("{}")
  executedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  testCycle       TestCycle        @relation(fields: [testCycleId], references: [id], onDelete: Cascade)
  testCaseVersion TestCaseVersion  @relation(fields: [testCaseVersionId], references: [id])
  assignee        User?            @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  stepExecutions  TestStepExecution[]
  defects         DefectLink[]
  attachments     Attachment[]

  @@index([testCycleId, status])
}

enum ExecutionStatus {
  NOT_RUN
  IN_PROGRESS
  PASS
  FAIL
  BLOCKED
  SKIPPED
}

model TestStepExecution {
  id              String          @id @default(cuid())
  executionId     String
  testStepId      String
  status          ExecutionStatus @default(NOT_RUN)
  actualResult    String?         @db.Text
  comment         String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  execution   TestCaseExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  testStep    TestStep          @relation(fields: [testStepId], references: [id])
  defects     DefectLink[]
  attachments Attachment[]

  @@index([executionId])
}

// ─── Test Plans ───────────────────────────────────────────────────────────────

model TestPlan {
  id          String     @id @default(cuid())
  key         String     // e.g. "PLN-1"
  summary     String
  description String?    @db.Text
  status      PlanStatus @default(DRAFT)
  isArchived  Boolean    @default(false)
  priorityId  String?
  folderId    String?
  projectId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder     Folder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)
  priority   Priority?      @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  cycles     TestPlanCycle[]

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([projectId, isArchived])
}

enum PlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model TestPlanCycle {
  testPlanId  String
  testCycleId String

  testPlan  TestPlan  @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  testCycle TestCycle @relation(fields: [testCycleId], references: [id], onDelete: Cascade)

  @@id([testPlanId, testCycleId])
}

// ─── Comments, Defects & Attachments ──────────────────────────────────────────

model SavedFilter {
  id        String @id @default(cuid())
  name      String
  entityType String  // "TEST_CASE", "TEST_CYCLE", "TEST_PLAN"
  criteria  Json    // { statuses: [], priorities: [], labels: [], etc }
  projectId String
  createdById String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User @relation("FilterCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([projectId, name, entityType])
  @@index([projectId, entityType])
}

model Comment {
  id              String    @id @default(cuid())
  body            String    @db.Text
  entityType      String    // "TEST_CASE", "TEST_CYCLE", "TEST_PLAN"
  entityId        String    // testCaseId, testCycleId, or testPlanId
  authorId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([authorId])
}

model DefectLink {
  id                  String  @id @default(cuid())
  jiraIssueKey        String  // e.g. "SHOP-789"
  jiraSummary         String?
  jiraStatus          String?
  jiraUrl             String?
  executionId         String?
  stepExecutionId     String?
  createdAt           DateTime @default(now())

  execution     TestCaseExecution? @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepExecution TestStepExecution? @relation(fields: [stepExecutionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([stepExecutionId])
}

model Attachment {
  id              String   @id @default(cuid())
  fileName        String
  fileSize        Int
  mimeType        String
  storageKey      String   // relative path or S3 key
  executionId     String?
  stepExecutionId String?
  createdById     String?
  createdAt       DateTime @default(now())

  execution     TestCaseExecution? @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepExecution TestStepExecution? @relation(fields: [stepExecutionId], references: [id], onDelete: Cascade)
  createdBy     User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([executionId])
}

// ─── Atlassian Connect ────────────────────────────────────────────────────────

model JiraTenant {
  id            String    @id @default(cuid())
  clientKey     String    @unique
  sharedSecret  String    @db.Text
  baseUrl       String
  productType   String    @default("jira")
  description   String?
  isActive      Boolean   @default(true)
  installedAt   DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  uninstalledAt DateTime?

  @@index([clientKey, isActive])
}

// ─── Automation Runs ──────────────────────────────────────────────────────────

model AutomationRun {
  id          String   @id @default(cuid())
  projectId   String
  testCycleId String?
  framework   String   // cypress | playwright | jest | testng | selenium
  status      String   @default("pending") // pending | processing | done | error
  totalTests  Int      @default(0)
  passed      Int      @default(0)
  failed      Int      @default(0)
  skipped     Int      @default(0)
  rawReport   Json?    // original submitted payload
  submittedAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCycle TestCycle? @relation(fields: [testCycleId], references: [id], onDelete: SetNull)

  @@index([projectId, submittedAt])
}
