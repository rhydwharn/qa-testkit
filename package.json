{
  "name": "qa-test-management",
  "version": "0.0.1",
  "private": true,
  "description": "Open-source QA Test Management Tool with JIRA integration",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/reporters/*"
  ],
  "author": "Ridwan Abdulazeez",
  "license": "GNU General Public License v3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rhydwharn/qa-testkit.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "cd apps/web && pnpm prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
